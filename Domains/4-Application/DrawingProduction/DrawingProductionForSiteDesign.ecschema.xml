<ECSchema schemaName="DrawingProductionForSiteDesign" alias="dpfsd" version="01.00.00"
    xmlns="http://www.bentley.com/schemas/Bentley.ECXML.3.2"
    description="Drawing Production schema for Site Design related concepts (OpenSite+).">
    <ECSchemaReference name="DrawingProduction" version="01.00.00" alias="dp" />
    <ECSchemaReference name="BisCustomAttributes" version="01.00.00" alias="bisCA" />
    <ECSchemaReference name="CoreCustomAttributes" version="01.00.04" alias="CoreCA" />

    <ECCustomAttributes>
        <ProductionStatus xmlns="CoreCustomAttributes.01.00.03">
            <SupportedUse>NotForProduction</SupportedUse>
        </ProductionStatus>
        <SchemaLayerInfo xmlns="BisCustomAttributes.01.00.00">
            <Value>Application</Value>
        </SchemaLayerInfo>
    </ECCustomAttributes>

    <ECEntityClass typeName="PlanDrawingRecipe" displayLabel="Plan Drawing Recipe"
        description="A recipe for creating plan drawings.">
        <BaseClass>dp:DrawingRecipe</BaseClass>
    </ECEntityClass>
    <ECEntityClass typeName="ProfileDrawingRecipe" displayLabel="Profile Drawing Recipe"
        description="A recipe for creating profile drawings.">
        <BaseClass>dp:DrawingRecipe</BaseClass>
    </ECEntityClass>

</ECSchema>
