<ECSchema schemaName="DrawingProduction" alias="dp" version="01.00.04"
    xmlns="http://www.bentley.com/schemas/Bentley.ECXML.3.2"
    description="This schema contains Drawing Production concepts. They should be considered domain agnostic.">
    <ECSchemaReference name="BisCore" version="01.00.25" alias="bis" />
    <ECSchemaReference name="BisCustomAttributes" version="01.00.00" alias="bisCA" />
    <ECSchemaReference name="CoreCustomAttributes" version="01.00.04" alias="CoreCA" />
    
    <ECCustomAttributes>
        <ProductionStatus xmlns="CoreCustomAttributes.01.00.03">
            <SupportedUse>NotForProduction</SupportedUse>
        </ProductionStatus>
        <SchemaLayerInfo xmlns="BisCustomAttributes.01.00.00">
            <Value>Application</Value>
        </SchemaLayerInfo>
    </ECCustomAttributes>

    <ECEntityClass typeName="DrawingRecipe" modifier="Abstract"
        displayLabel="Drawing Recipe"
        description="A subclass of a bis:RecipeDefinitionElement that defines a recipe for creating drawings.">
        <BaseClass>bis:RecipeDefinitionElement</BaseClass>
        <ECProperty propertyName="Settings" typeName="string" extendedTypeName="Json"
            displayLabel="Settings"
            description="The settings for the drawing recipe in a versioned JSON format." />
    </ECEntityClass>

    <ECEntityClass typeName="BlankDrawingRecipe" displayLabel="Blank Drawing Recipe"
        description="A recipe for creating blank drawings. For example, Standard Details.">
        <BaseClass>DrawingRecipe</BaseClass>
    </ECEntityClass>

    <ECEntityClass typeName="NorthArrowCallout" displayLabel="North Arrow Callout" modifier="None"
        description="A bis:AnnotationElement2d that displays a north arrow on a sheet.">
        <BaseClass>bis:AnnotationElement2d</BaseClass>
    </ECEntityClass>

    <ECEntityClass typeName="NorthArrowCalloutDefinition" displayLabel="North Arrow Callout Definition" modifier="None"
        description="A bis:GraphicalType2d that defines the properties of a NorthArrowCallout.">
        <BaseClass>bis:GraphicalType2d</BaseClass>
    </ECEntityClass>
    
    <ECEntityClass typeName="ScaleBarCallout" displayLabel="Scale Bar Callout" modifier="None"
        description="A bis:AnnotationElement2d that displays a scale bar on a sheet.">
        <BaseClass>bis:AnnotationElement2d</BaseClass>
        <ECProperty propertyName="Settings" typeName="string" extendedTypeName="Json" displayLabel="Settings" description="The settings for a scale bar in a versioned JSON format." />
    </ECEntityClass>

    <ECEntityClass typeName="ScaleBarCalloutDefinition" displayLabel="Scale Bar Callout Definition" modifier="None"
        description="A bis:GraphicalType2d that defines the properties of a ScaleBarCallout.">
        <BaseClass>bis:GraphicalType2d</BaseClass>
        <ECProperty propertyName="Settings" typeName="string" extendedTypeName="Json" displayLabel="Settings" description="The settings for a scale bar in a versioned JSON format." />
        <ECProperty propertyName="Description" typeName="string" description="Description of the style" />
    </ECEntityClass>
</ECSchema>
